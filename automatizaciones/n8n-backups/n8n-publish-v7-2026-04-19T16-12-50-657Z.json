    {
      "parameters": {
        "jsCode": "const items = $input.all().map(item => item.json);\nconst piece = $('Prepare Publish Data').first().json;\n\nconst ig = items.find(i => i.platform === 'ig') || { ok: false, postId: null, error: 'Branch did not execute' };\nconst fb = items.find(i => i.platform === 'fb') || { ok: false, postId: null, error: 'Branch did not execute' };\n\n// Anti-duplicate: solo grabar si al menos una red publicó\nif (ig.ok || fb.ok) {\n  const staticData = $getWorkflowStaticData('global');\n  staticData.lastPublished = piece.pieceId + '_' + piece.date;\n}\n\nconst igUrl = 'https://www.instagram.com/espacionauticobsas/';\nconst fbUrl = fb.postId ? 'https://www.facebook.com/' + fb.postId : 'N/A';\n\nconst bothOk = ig.ok && fb.ok;\nconst bothFailed = !ig.ok && !fb.ok;\n\nvar subject;\nif (bothOk) {\n  subject = 'ENBA Redes: ' + piece.pieceId + ' publicado IG+FB - ' + piece.headline;\n} else if (bothFailed) {\n  subject = '[ERROR CRITICO] ENBA Redes: ' + piece.pieceId + ' FALLO IG+FB';\n} else {\n  var okPlatform = ig.ok ? 'IG' : 'FB';\n  var failPlatform = ig.ok ? 'FB' : 'IG';\n  subject = '[PARCIAL] ENBA Redes: ' + piece.pieceId + ' ' + okPlatform + ' ok, ' + failPlatform + ' fallo';\n}\n\nvar body = 'PUBLICACION REDES - ENBA\\n'\n  + '========================\\n\\n'\n  + 'Pieza: ' + piece.pieceId + '\\n'\n  + 'Fecha: ' + piece.date + '\\n'\n  + 'Vertical: ' + piece.vertical + '\\n'\n  + 'Headline: ' + piece.headline + '\\n\\n'\n  + '--- INSTAGRAM ---\\n'\n  + 'Estado: ' + (ig.ok ? 'PUBLICADO' : 'FALLO') + '\\n'\n  + (ig.ok ? '  Post ID: ' + ig.postId + '\\n  Ver: ' + igUrl + '\\n' : '  Error: ' + ig.error + '\\n')\n  + '\\n--- FACEBOOK ---\\n'\n  + 'Estado: ' + (fb.ok ? 'PUBLICADO' : 'FALLO') + '\\n'\n  + (fb.ok ? '  Post ID: ' + fb.postId + '\\n  Ver: ' + fbUrl + '\\n' : '  Error: ' + fb.error + '\\n')\n  + '\\nTimestamp: ' + new Date().toISOString();\n\nif (!ig.ok || !fb.ok) {\n  body += '\\n\\nACCION REQUERIDA: revisar plataforma(s) fallida(s) y reintentar manualmente.';\n}\n\nreturn [{ json: { subject: subject, body: body, igOk: ig.ok, fbOk: fb.ok, pieceId: piece.pieceId } }];\n"
      },
