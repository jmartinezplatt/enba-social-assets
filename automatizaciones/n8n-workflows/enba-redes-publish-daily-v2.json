      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "n8scJzbGXnCprioD",
          "name": "Meta API ENBA"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{ $('Prepare Publish Data').first().json.pageId }}/photos?url={{ encodeURIComponent($('Prepare Publish Data').first().json.imageUrl) }}&message={{ encodeURIComponent($('Prepare Publish Data').first().json.captionFb) }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "node-fb-publish",
      "name": "FB Publish",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2180,
        200
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "n8scJzbGXnCprioD",
          "name": "Meta API ENBA"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const piece = $('Prepare Publish Data').first().json;\nconst igResult = $('IG Publish').first().json;\nconst fbResult = $('FB Publish').first().json;\n\nconst igId = igResult.id || 'ERROR';\nconst fbId = fbResult.id || 'ERROR';\n\nconst igUrl = 'https://www.instagram.com/espacionauticobsas/';\nconst fbUrl = 'https://www.facebook.com/' + fbId;\n\nconst ok = igId !== 'ERROR' && fbId !== 'ERROR';\n\nconst subject = ok\n  ? 'ENBA Redes: ' + piece.pieceId + ' publicado - ' + piece.headline\n  : 'ENBA Redes ERROR: ' + piece.pieceId + ' fallo';\n\nconst body = 'PUBLICACION REDES - ENBA\\n'\n  + '========================\\n\\n'\n  + 'Pieza: ' + piece.pieceId + '\\n'\n  + 'Fecha: ' + piece.date + '\\n'\n  + 'Vertical: ' + piece.vertical + '\\n'\n  + 'Headline: ' + piece.headline + '\\n\\n'\n  + 'Instagram: ' + (igId !== 'ERROR' ? 'PUBLICADO' : 'FALLO') + '\\n'\n  + '  Post ID: ' + igId + '\\n'\n  + '  Ver en vivo: ' + igUrl + '\\n\\n'\n  + 'Facebook: ' + (fbId !== 'ERROR' ? 'PUBLICADO' : 'FALLO') + '\\n'\n  + '  Post ID: ' + fbId + '\\n'\n  + '  Ver en vivo: ' + fbUrl + '\\n\\n'\n  + 'Timestamp: ' + new Date().toISOString();\n\nreturn [{ json: { subject, body, igId, fbId, pieceId: piece.pieceId } }];\n"
      },
      "id": "node-prepare-email",
      "name": "Prepare Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
