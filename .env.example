# ============================================================
# enba-social-assets — Variables de entorno
# ============================================================
#
# SECRETS (tokens, app secret) NO van en este archivo.
# Viven en Windows User scope. Leer con:
#   powershell -Command "[System.Environment]::GetEnvironmentVariable('NOMBRE','User')"
#
# Variables de Windows User scope (secrets):
#   META_ACCESS_TOKEN        — Page Access Token LL (owner: frente lanzamiento/redes)
#   META_ADS_USER_TOKEN      — User Access Token LL (owner: frente 10K/ads)
#   META_APP_SECRET          — App Secret
#   N8N_API_KEY              — API key de n8n cloud
#
# El workflow n8n usa credencial encriptada "Meta API ENBA" (no lee de aquí).
# ============================================================

# IDs públicos (no son secrets)
META_PAGE_ID=1064806400040502
